# Frontend server
HOST=0.0.0.0
PORT=5000
NODE_ENV=production

# Upstream ML backend (container DNS in docker-compose)
ECESSP_ML_URL=http://ecessp-ml:8000

# Public client-side API base for static/Vercel deployments.
# Example: https://api.ecessp.online/api
VITE_ECESSP_API_BASE=/api

# Optional auth gate for UI routes
AUTH_ENABLED=1
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
AUTH_TOKEN_TTL_SEC=43200

# Proxy hardening
PROXY_TIMEOUT_MS=30000
PROXY_RETRIES=2
FORWARD_CLIENT_AUTH_HEADER=0
FORWARD_CLIENT_API_KEY=0

# Optional forwarding to backend
ECESSP_API_KEY=
ECESSP_BEARER_TOKEN=

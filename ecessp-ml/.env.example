# Backend network
PORT=8000
USE_GPU=0
ECESSP_ALLOWED_ORIGINS=https://ecessp.online,https://www.ecessp.online

# Security
ECESSP_API_KEY=change-me
ECESSP_BEARER_TOKEN=
REQUIRE_API_KEY=1
REQUIRE_BEARER_TOKEN=0

# Reliability
RATE_LIMIT_ENABLED=1
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SEC=60
REQUEST_TIMEOUT_SEC=60

# Optional explicit checkpoint override (absolute or project-relative path)
# ECESSP_CHECKPOINT=reports/models/best_model_layer_norm_20260214_133657.pt

# Prediction uncertainty policy
# Modes: reject | fallback | explain
ECESSP_PREDICTION_UNCERTAINTY_MODE=reject
ECESSP_PREDICTION_UNCERTAINTY_MEDIUM=0.20
ECESSP_PREDICTION_UNCERTAINTY_HIGH=0.35
ECESSP_REJECT_ON_GUARDRAIL_REJECT=1

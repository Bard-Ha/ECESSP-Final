    "warnings",
    "formula_charge",
    "formula_discharge",
    "max_delta_volume",
    "average_voltage",
    "capacity_grav",
    "capacity_vol",
    "energy_grav",
    "energy_vol",
    "fracA_charge",
    "fracA_discharge",
    "stability_charge",
    "stability_discharge",
    "id_charge",
    "id_discharge",
    "host_structure",
